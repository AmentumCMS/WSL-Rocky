# =============================================================================
# packages.list — Additional packages to install in the WSL image
#
# Format:
#   - One package name per line
#   - Lines beginning with # are comments
#   - Blank lines are ignored
#   - Use the exact dnf package name (e.g. `dnf search <term>`)
#
# These packages are installed BEFORE STIG hardening so that hardening rules
# (e.g., setting file permissions on config files) apply to them.
# Add org-specific packages in the sections below.
# =============================================================================

# ── Core utilities ────────────────────────────────────────────────────────────
bash-completion
man-db
less
vim
nano
wget
curl
unzip
zip
jq
tree
htop
tmux
screen

# ── Networking ────────────────────────────────────────────────────────────────
iputils
net-tools
bind-utils
nmap
traceroute
ncat
iproute
openssh-clients

# ── Security utilities ────────────────────────────────────────────────────────
openssl
gnupg2
fail2ban
firewalld
aide
rkhunter

# ── Development tools (remove if not needed) ─────────────────────────────────
# On Rocky Linux, use `dnf groupinstall "Development Tools"` for a full
# development environment, or install individual packages:
# git
# gcc
# make
# python3
# python3-pip
# python3-venv
# nodejs
# npm

# ── Monitoring & observability ────────────────────────────────────────────────
sysstat
lsof
strace
ltrace

# ── Organization-specific packages ───────────────────────────────────────────
# Add your organization's required packages below:
#
# Example:
#   myorg-ca-certificates
#   myorg-proxy-config
